  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "tsx --test test/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "inference",
