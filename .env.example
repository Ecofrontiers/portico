# Portico — Environment Variables
# Copy to .env and fill in your values.
# All settings can also be configured in portico.yml.

# --- Server ---
PORT=3040
HOST=0.0.0.0

# --- Authentication (optional — enables API key requirement) ---
# Comma-separated list of valid API keys. When set, auth is auto-enabled.
# PORTICO_API_KEYS=pk-key1,pk-key2

# --- Remote Providers (optional — only needed if you configure remote backends) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# --- Carbon-Aware Routing (optional) ---
# Get a free key at https://api-portal.electricitymaps.com/
ELECTRICITY_MAPS_API_KEY=

# --- Config File Path (optional, defaults to ./portico.yml) ---
# PORTICO_CONFIG=./portico.yml
